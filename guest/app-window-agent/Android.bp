package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

android_app {
    name: "GreenhouseAppWindowAgent",
    srcs: ["src/**/*.java"],
    resource_dirs: ["res"],
    manifest: "AndroidManifest.xml",
    platform_apis: true,
    privileged: true,
    certificate: "platform",
    system_ext_specific: true,
    required: ["privapp-permissions-greenhouse-app-window"],
    optimize: {
        enabled: false,
    },
}

prebuilt_etc {
    name: "privapp-permissions-greenhouse-app-window",
    src: "permissions/privapp-permissions-greenhouse-app-window.xml",
    filename_from_src: true,
    sub_dir: "permissions",
    system_ext_specific: true,
}
